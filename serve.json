{
  "cleanUrls": true,
  "redirects": [
    { "source": "/home", "destination": "/index.html" },
    { "source": "/main", "destination": "/index.html" },
    { "source": "/bio", "destination": "/about.html" },
    { "source": "/contacts", "destination": "/contact.html" },
    { "source": "/video", "destination": "/videos.html" },
    { "source": "/interests", "destination": "/interest.html" },
    { "source": "/hobbies", "destination": "/interest.html" },
    { "source": "/resume", "destination": "/about.html" },
    { "source": "/portfolio", "destination": "/journey.html" },
    { "source": "/path", "destination": "/journey.html" },
    { "source": "/404", "destination": "/404.html" }
  ],
  "headers": [
    {
      "source": "**/*",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "**/*.@(js|css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "**/*.@(png|jpg|jpeg|gif|svg|ico|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "**/*.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
